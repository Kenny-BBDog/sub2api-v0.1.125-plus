# Copy this file to .env and replace every change-me value before starting.

COMPOSE_PROJECT_NAME=sub2api
BIND_HOST=0.0.0.0
SERVER_PORT=18084
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=sub2api

REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=change-me-admin-password

# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-64-hex-jwt-secret
TOTP_ENCRYPTION_KEY=change-me-64-hex-totp-key

# Optional outbound proxy. Leave empty for direct egress.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis

